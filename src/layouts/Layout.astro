---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown>;
  bare?: boolean;
  emoji?: string;
}

const { title, description, canonical, schema, bare = false, emoji } = Astro.props;
const siteUrl = 'https://marijnbent.nl';
const currentPath = Astro.url.pathname;
const canonicalUrl = canonical || `${siteUrl}${currentPath}`;
// Extract project name from title like "VibeScribe – Marijn Bent"
const projectName = title.includes(' – ') ? title.split(' – ')[0] : title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Marijn Bent" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Schema.org JSON-LD -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <script defer src="https://analytics.cowsandbytes.party/script.js" data-website-id="4effb6d5-fab0-4937-bdbc-3b3e6de7e0a5"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-white font-sans antialiased" style="font-family: 'Inter', sans-serif;">
    {bare ? (
      <slot />
    ) : (
      <div class="mx-auto max-w-2xl px-6 pt-10 pb-20">

        <!-- Back nav -->
        <nav class="mb-14">
          <a href="/" class="inline-flex items-center gap-1.5 text-sm text-black/35 hover:text-black transition-colors duration-150">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M8.5 2.5L4 7L8.5 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Marijn Bent
          </a>
        </nav>

        <!-- Project header -->
        <header class="mb-10">
          {emoji && <div class="text-4xl mb-5 leading-none">{emoji}</div>}
          <h1 class="text-[2.5rem] font-bold tracking-[-0.03em] leading-tight text-black mb-3">
            {projectName}
          </h1>
          <p class="text-base text-black/45 leading-relaxed max-w-lg">{description}</p>
        </header>

        <hr class="border-black/[0.08] mb-10" />

        <main class="project-page">
          <slot />
        </main>

      </div>
    )}
  </body>
</html>
