---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Marijn Bent",
  "url": "https://marijnbent.nl",
  "description": "Mostly working with AI and smart contracts. But I love creating web applications with Laravel, Vue and some Python for scripts."
};

const projects = [
  {
    name: "🎤 VibeScribe",
    href: "/vibescribe/",
    description: "macOS speech-to-text with AI enhancement - hold a key, talk, paste."
  },
  {
    name: "📚 BookLite",
    href: "/booklite/",
    description: "Self-hosted digital library with Kobo sync for households and small teams."
  },
  {
    name: "🍽️ Prepped",
    href: "/prepped/",
    description: "Self-hosted recipe app. Import recipes from URLs with AI, scale servings, and keep everything on your own server."
  },
  {
    name: "💼 Hiredd",
    href: "/hiredd/",
    description: "Job application tracker to keep your pipeline organized."
  },
  {
    name: "🎮 OpenFront Enhanced",
    href: "/openfront-extension/",
    description: "Browser extension that adds useful overlays to the OpenFront.io strategy game."
  },
  {
    name: "🔧 Parkside.fans",
    href: "/parkside-fans/",
    description: "Fan community site for Parkside / LIDL tools."
  },
  {
    name: "₿ Bitcoin simulator",
    href: "/bitcoin-simulator/",
    description: "See what your investment would be worth if you had bought Bitcoin at any point in the past."
  },
  {
    name: "🖨️ Obsidian Print",
    href: "/obsidian-print/",
    description: "Obsidian plugin that adds a print option directly, no PDF export needed."
  }
];
---

<Layout
  title="Marijn Bent"
  description="Mostly working with AI and smart contracts. But I love creating web applications with Laravel, Vue and some Python for scripts."
  schema={schema}
>
  <div class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight mb-4">Marijn Bent</h1>
    <p class="text-muted-foreground leading-relaxed mb-3">
      Mostly working with AI and smart contracts. But I love creating web applications with Laravel, Vue and some Python for scripts.
    </p>
    <a href="https://github.com/marijnbent" class="text-sm text-muted-foreground hover:text-foreground transition-colors">GitHub →</a>
  </div>

  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
    {projects.map(project => (
      <a
        href={project.href}
        class="group block rounded-lg border border-border p-4 hover:border-foreground/30 transition-colors"
      >
        <div class="font-medium text-foreground group-hover:text-foreground/80 transition-colors mb-1">{project.name}</div>
        <div class="text-sm text-muted-foreground leading-relaxed">{project.description}</div>
      </a>
    ))}
  </div>
</Layout>
