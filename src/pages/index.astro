---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Marijn Bent",
  "url": "https://marijnbent.nl",
  "description": "Mostly working with AI and smart contracts. But I love creating web applications with Laravel, Vue and some Python for scripts."
};

const projects = [
  {
    name: "VibeScribe",
    emoji: "🎤",
    href: "/vibescribe/",
    description: "macOS speech-to-text with AI enhancement — hold a key, talk, paste."
  },
  {
    name: "BookLite",
    emoji: "📚",
    href: "/booklite/",
    description: "Self-hosted digital library with Kobo sync for households and small teams."
  },
  {
    name: "Prepped",
    emoji: "🍽️",
    href: "/prepped/",
    description: "Self-hosted recipe app. Import recipes from URLs with AI, scale servings, and keep everything on your own server."
  },
  {
    name: "Hiredd",
    emoji: "💼",
    href: "/hiredd/",
    description: "Job application tracker to keep your pipeline organized."
  },
  {
    name: "OpenFront Enhanced",
    emoji: "🎮",
    href: "/openfront-extension/",
    description: "Browser extension that adds useful overlays to the OpenFront.io strategy game."
  },
  {
    name: "Parkside.fans",
    emoji: "🔧",
    href: "/parkside-fans/",
    description: "Fan community site for Parkside / LIDL tools."
  },
  {
    name: "Bitcoin simulator",
    emoji: "₿",
    href: "/bitcoin-simulator/",
    description: "See what your investment would be worth if you had bought Bitcoin at any point in the past."
  },
  {
    name: "Obsidian Print",
    emoji: "🖨️",
    href: "/obsidian-print/",
    description: "Obsidian plugin that adds a print option directly, no PDF export needed."
  }
];
---

<Layout
  title="Marijn Bent"
  description="Mostly working with AI and smart contracts. But I love creating web applications with Laravel, Vue and some Python for scripts."
  schema={schema}
  bare={true}
>
  <div class="min-h-screen bg-white">

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="flex flex-col items-center justify-center px-6 pt-24 pb-20 text-center">

      <!-- Outlined pill badge -->
      <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-black/[0.12] bg-white px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.1em] text-black/50 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
        <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
        Builder &amp; Developer
      </div>

      <!-- Massive heading — Inter 900, tight tracking, newspaper weight -->
      <h1
        class="max-w-3xl text-[clamp(3rem,8vw,6rem)] font-bold leading-[0.95] tracking-[-0.03em] text-black"
      >
        Marijn Bent.
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 max-w-sm text-[1.0625rem] leading-relaxed text-black/45 font-normal">
        Building with AI, smart contracts, and the occasional web application.
      </p>

      <!-- GitHub link as a pill button -->
      <a
        href="https://github.com/marijnbent"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-black px-5 py-2.5 text-sm font-semibold text-white transition-all duration-150 hover:bg-black/80 active:scale-[0.97]"
      >
        <!-- GitHub icon -->
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        GitHub
      </a>
    </section>

    <!-- ── DIVIDER ────────────────────────────────────────────────── -->
    <div class="mx-auto max-w-4xl px-6">
      <hr class="border-black/[0.07]" />
    </div>

    <!-- ── PROJECTS ───────────────────────────────────────────────── -->
    <section class="mx-auto max-w-4xl px-6 py-16">

      <!-- Section heading -->
      <div class="mb-8 flex items-baseline gap-3">
        <h2 class="text-2xl font-bold tracking-tight text-black">Projects</h2>
        <span class="text-sm font-medium text-black/30">{projects.length}</span>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        {projects.map(project => (
          <a
            href={project.href}
            class="group relative flex flex-col rounded-xl border border-black/[0.08] bg-white p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-black/[0.14] hover:shadow-[0_4px_20px_-4px_rgba(0,0,0,0.12)]"
          >
            <!-- Emoji watermark -->
            <span
              class="mb-3 text-2xl leading-none"
              aria-hidden="true"
            >{project.emoji}</span>

            <div class="font-semibold text-black tracking-tight mb-1.5 group-hover:text-black/80 transition-colors duration-150">
              {project.name}
            </div>
            <div class="text-sm text-black/45 leading-relaxed">
              {project.description}
            </div>

            <!-- Subtle arrow that appears on hover -->
            <svg
              class="absolute right-4 top-1/2 -translate-y-1/2 opacity-0 translate-x-1 transition-all duration-200 group-hover:opacity-30 group-hover:translate-x-0"
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
            >
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>
    </section>

    <!-- ── FOOTER ────────────────────────────────────────────────── -->
    <footer class="mx-auto max-w-4xl px-6 py-10 border-t border-black/[0.07]">
      <p class="text-xs text-black/30 font-medium">
        &copy; {new Date().getFullYear()} Marijn Bent
      </p>
    </footer>

  </div>
</Layout>
